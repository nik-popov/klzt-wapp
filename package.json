{
  "name": "klzt",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n vite,worker -c cyan,magenta \"npm:dev:web\" \"npm:dev:worker\"",
    "dev:web": "vite",
    "dev:worker": "wrangler dev",
    "build": "vite build",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply klzt --local",
    "db:migrate:remote": "wrangler d1 migrations apply klzt --remote",
    "db:seed:local": "wrangler d1 execute klzt --local --file=./seeds/demo.sql",
    "db:seed:remote": "wrangler d1 execute klzt --remote --file=./seeds/demo.sql",
    "db:seed:closet:local": "wrangler d1 execute klzt --local --file=./seeds/closet.sql",
    "db:seed:closet:remote": "wrangler d1 execute klzt --remote --file=./seeds/closet.sql",
    "seed:r2:local": "bash seeds/upload-r2.sh local",
    "seed:r2:remote": "bash seeds/upload-r2.sh remote",
    "setup:local": "npm run db:migrate:local && npm run db:seed:local && npm run db:seed:closet:local && npm run seed:r2:local",
    "setup:remote": "npm run db:migrate:remote && npm run db:seed:remote && npm run db:seed:closet:remote && npm run seed:r2:remote",
    "typecheck": "tsc -b",
    "lint": "eslint \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-query": "^5.51.0",
    "clsx": "^2.1.1",
    "hono": "^4.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240725.0",
    "@types/node": "^26.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.9",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4",
    "vite": "^5.3.5",
    "wrangler": "^3.68.0"
  }
}
